<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.samsung.android.game.gos"
    android:sharedUserId="android.uid.system"
    android:versionCode="350200000"
    android:versionName="3.5.02.0">

    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS" />
    <uses-permission android:name="android.permission.REAL_GET_TASKS" />
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS" />
    <uses-permission android:name="android.permission.SET_ANIMATION_SCALE" />
    <uses-permission android:name="com.samsung.android.permission.HARDWARE_INFO" />
    <uses-permission android:name="com.samsung.android.permission.SSM_ACCESS" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.KILL_BACKGROUND_PROCESSES" />
    <uses-permission android:name="android.permission.CHANGE_CONFIGURATION" />
    <uses-permission android:name="android.permission.HARDWARE_TEST" />
    <uses-permission android:name="android.permission.DUMP" />
    <uses-permission android:name="android.permission.MODIFY_PHONE_STATE" />

    <application
        android:allowBackup="false"
        android:directBootAware="true"
        android:extractNativeLibs="false"
        android:label="Game Optimization Service"
        android:persistent="true"
        android:process="com.samsung.android.game.gos">

        <service
            android:name="com.samsung.android.game.gos.service.GosService"
            android:exported="true"
            android:singleUser="true">
            <intent-filter>
                <action android:name="com.samsung.android.game.gos.service.GosService" />
            </intent-filter>
        </service>

        <service
            android:name="com.samsung.android.game.gos.ipm.IpmService"
            android:exported="false" />

        <service
            android:name="com.samsung.android.game.gos.service.FeatureFlagService"
            android:exported="false" />

        <receiver
            android:name="com.samsung.android.game.gos.receiver.BootCompletedReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name="com.samsung.android.game.gos.receiver.PackageEventReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.PACKAGE_ADDED" />
                <action android:name="android.intent.action.PACKAGE_REMOVED" />
                <action android:name="android.intent.action.PACKAGE_REPLACED" />
                <data android:scheme="package" />
            </intent-filter>
        </receiver>

        <receiver
            android:name="com.samsung.android.game.gos.receiver.ThermalReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.samsung.intent.action.EMERGENCY_STATE_CHANGED" />
            </intent-filter>
        </receiver>

        <provider
            android:name="com.samsung.android.game.gos.data.db.GosContentProvider"
            android:authorities="com.samsung.android.game.gos.provider"
            android:exported="true"
            android:permission="com.samsung.android.game.gos.permission.ACCESS_PROVIDER" />

        <activity
            android:name="com.samsung.android.game.gos.ui.MainActivity"
            android:exported="true"
            android:theme="@android:style/Theme.NoDisplay">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.samsung.android.game.gos.controller.DummyActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

    </application>
</manifest>
